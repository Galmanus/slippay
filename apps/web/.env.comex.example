# Slippay COMEX (tesouraria B2B · Base) — variáveis de ambiente da Fase 1
# Copie pro .env de produção e preencha. O comex roda em Base (EVM) — a 4P
# liquida USDC na Base. Sem o Privy App ID o app compila e a rota /comex mostra
# a business landing (não quebra). Ver docs/comex-go-live-checklist.md.

# --- liga a rota /comex transacional (sem o Privy App ID → business landing) ---
VITE_COMEX_ENABLED=1

# --- Privy (conta da empresa: e-mail/senha + MFA, carteira EVM non-custodial) ---
# criar app em dashboard.privy.io: login só e-mail, MFA on, embedded wallet
# Ethereum/EVM createOnLogin, chain Base (8453). NÃO secret no front (non-custodial).
VITE_PRIVY_APP_ID=                    # ex: clxxxxxxxxxxxxx — ÚNICO bloqueio pra go-live

# --- rede Base ---
VITE_BASE_NETWORK=mainnet             # mainnet | sepolia (teste)
VITE_BASE_RPC=                        # RPC pago (Alchemy/QuickNode); senão cai no público (frágil)
# USDC mainnet na Base é fixo no código (Circle 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913) — não setar

# --- câmbio R$<->USD: 4P (JÁ configurado no backend de prod) ---
# FOURP_API_KEY / FOURP_CHAIN=Base / FOURP_ASSET=USDC já estão no .env do servidor.
# Off-ramp (vender USDC->R$) pendente do endpoint da 4P:
VITE_4P_OFFRAMP_RECEIVER=             # endereço 0x da 4P (pino de segurança da venda; vazio = venda desabilitada)

# --- guardas corporativas ---
VITE_COMEX_APPROVAL_USD=5000          # acima disso, exige confirmação adicional
