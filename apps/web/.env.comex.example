# Slippay COMEX (tesouraria B2B) — variáveis de ambiente da Fase 1
# Copie pro .env de produção e preencha. Sem essas chaves o app compila e roda,
# mas os fluxos que dependem de parceiro retornam erro até a chave existir.

# --- liga a rota /comex (sem isso, rota = not-found, seguro em prod) ---
VITE_COMEX_ENABLED=1

# --- rede Stellar ---
VITE_STELLAR_NETWORK=PUBLIC          # PUBLIC (mainnet) | TESTNET (pra testar)

# --- Privy (conta da empresa: login e-mail/senha + MFA, carteira Stellar non-custodial) ---
# crie um app em dashboard.privy.io, habilite MFA, habilite extended-chains/Stellar.
VITE_PRIVY_APP_ID=                   # ex: clxxxxxxxxxxxxx
# NÃO existe secret/authorization key no cliente (é user wallet, non-custodial).

# --- PagFinance (câmbio R$<->USD, parceiro licenciado, em Stellar) ---
VITE_PAGFINANCE_ENABLED=1
VITE_PAGFINANCE_BASE=https://app.pag.finance
VITE_PAGFINANCE_CLIENT_ID=slippay    # client-id registrado com eles (DM)
VITE_PAGFINANCE_DOMAIN=app.slippay.cc
# o JWT da PagFinance é setado em runtime via setPagToken() (não fica no env)

# --- DeFindex (rendimento do dólar parado) ---
VITE_DEFINDEX_API_KEY=               # pedir no Discord da DeFindex
VITE_DEFINDEX_BASE=https://api.defindex.io
VITE_DEFINDEX_USDC_VAULT=            # endereço C... do vault USDC.
# ANTES de setar mainnet aqui: verificar on-chain is_upgradable=false / Manager
# conhecido (gate de custódia do threat-model).

# --- guardas corporativas ---
VITE_COMEX_APPROVAL_USD=5000         # acima disso, exige confirmação adicional
